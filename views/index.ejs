<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body class="bg-slate-900 text-slate-200 min-h-screen flex items-center justify-center p-4 font-sans">
  <div class="max-w-4xl w-full bg-slate-800 rounded-2xl shadow-2xl overflow-hidden border border-slate-700/50">
    <div class="p-8 sm:p-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-center text-white mb-2 tracking-tight">
        <%= title %>
      </h1>
      <p class="text-slate-400 text-center text-sm mb-10">
        成功啟動並連接至 PostgreSQL 資料庫系統。
      </p>

      <!-- Database Connection Info -->
      <div class="grid gap-4 sm:grid-cols-2 mb-10">
        <!-- Database IP Card -->
        <div
          class="bg-slate-900/50 rounded-xl p-4 border border-slate-700/50 flex flex-col items-center justify-center transition hover:bg-slate-700/30">
          <span class="text-slate-500 text-xs font-medium mb-1 uppercase tracking-wider">Database IP</span>
          <div class="flex items-center space-x-2">
            <span class="relative flex h-2 w-2">
              <span
                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-xl font-mono text-emerald-400 font-semibold">
              <%= dbIp %>
            </span>
          </div>
        </div>

        <!-- Database Port Card -->
        <div
          class="bg-slate-900/50 rounded-xl p-4 border border-slate-700/50 flex flex-col items-center justify-center transition hover:bg-slate-700/30">
          <span class="text-slate-500 text-xs font-medium mb-1 uppercase tracking-wider">Connection Port</span>
          <div class="flex items-center space-x-2">
            <svg class="w-4 h-4 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-xl font-mono text-amber-400 font-semibold">
              <%= dbPort %>
            </span>
          </div>
        </div>
      </div>

      <!-- Application Functions -->
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Left Column: Forms -->
        <div class="space-y-8">
          <!-- Save to DB Form -->
          <div class="bg-slate-900/40 p-6 rounded-xl border border-slate-700/50">
            <h2 class="text-lg font-semibold text-white mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
              </svg>
              文字數據管理 (PostgreSQL)
            </h2>
            <form id="textForm" class="flex flex-col space-y-3">
              <input type="text" id="textInput" placeholder="輸入要存入資料庫的文字" required
                class="bg-slate-800 border border-slate-600 rounded-lg px-4 py-2 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" />
              <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 rounded-lg transition duration-200">
                新增至資料庫
              </button>
            </form>
          </div>

          <!-- Save to File Form -->
          <div class="bg-slate-900/40 p-6 rounded-xl border border-slate-700/50">
            <h2 class="text-lg font-semibold text-white mb-4 flex items-center">
              <svg class="w-5 h-5 mr-2 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
              </svg>
              儲存實體檔案 (Volume)
            </h2>
            <form id="saveTextForm" class="flex flex-col space-y-3 mb-4">
              <input type="text" id="saveText" placeholder="輸入文字以建立 text.txt" required
                class="bg-slate-800 border border-slate-600 rounded-lg px-4 py-2 text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-transparent transition" />
              <button type="submit"
                class="bg-pink-600 hover:bg-pink-500 text-white font-medium py-2 rounded-lg transition duration-200">
                覆寫實體文字檔
              </button>
            </form>

            <!-- File Content Display -->
            <div class="mt-4 pt-4 border-t border-slate-700/50">
              <h3 class="text-sm font-semibold text-slate-400 mb-2">📄 /dist/text.txt 目前內容：</h3>
              <div
                class="bg-slate-800 rounded-lg p-3 text-slate-300 font-mono text-sm min-h-[60px] break-all border border-slate-700 flex items-center"
                id="fileContentDisplay">
                <span class="animate-pulse">載入中...</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: List -->
        <div class="bg-slate-900/40 p-6 rounded-xl border border-slate-700/50 flex flex-col h-full max-h-[400px]">
          <h2 class="text-lg font-semibold text-white mb-4 flex items-center pb-2 border-b border-slate-700">
            <svg class="w-5 h-5 mr-2 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            存儲的文字數據
          </h2>
          <ul id="textList" class="flex-1 overflow-y-auto space-y-2 pr-2 custom-scrollbar">
            <!-- JS 會塞入 <li> -->
          </ul>
        </div>
      </div>
    </div>

    <div
      class="bg-slate-900 px-8 py-4 border-t border-slate-700/50 flex justify-between items-center text-sm text-slate-500 font-mono">
      <span>Powered by TailwindCSS & Docker</span>
      <span class="flex items-center">Status: <span class="text-emerald-400 ml-2">Active</span></span>
    </div>
  </div>

  <style>
    /* Custom Scrollbar for the list */
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
      background: rgba(30, 41, 59, 0.5);
      border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: rgba(71, 85, 105, 0.8);
      border-radius: 10px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
      background: rgba(100, 116, 139, 1);
    }
  </style>

  <script>
    // 處理資料庫表單
    document.getElementById('textForm').addEventListener('submit', function (e) {
      e.preventDefault();
      const textInput = document.getElementById('textInput');
      const text = textInput.value;
      axios.post('/text', { text })
        .then((response) => {
          textInput.value = ''; // 清空輸入框
          fetchTextData(); // 重新獲取所有數據
        })
        .catch((error) => console.error('新增失敗:', error));
    });

    // 處理檔案表單
    document.getElementById('saveTextForm').addEventListener('submit', function (e) {
      e.preventDefault();
      const textInput = document.getElementById('saveText');
      const text = textInput.value;
      const btn = this.querySelector('button');
      const originalText = btn.textContent;
      btn.textContent = '儲存中...';

      axios.post('/text/savetext', { text })
        .then((response) => {
          textInput.value = ''; // 清空輸入框
          fetchFileContent(); // 重新抓取檔案內容
          btn.textContent = '儲存成功！';
          setTimeout(() => { btn.textContent = originalText; }, 1500);
        })
        .catch((error) => {
          console.error('新增失敗:', error);
          btn.textContent = originalText;
        });
    });

    // 抓取檔案內容並更新顯示
    function fetchFileContent() {
      axios.get('/text/filecontent')
        .then((response) => {
          const display = document.getElementById('fileContentDisplay');
          display.textContent = response.data;
        })
        .catch((error) => console.error('獲取檔案內容失敗:', error));
    }

    // 刪除單項資料
    function deleteText(id) {
      if (!confirm('確定要刪除這筆資料嗎？')) return;
      axios.delete(`/text/${id}`)
        .then(() => fetchTextData()) // 重新整理列表
        .catch((error) => console.error('刪除失敗:', error));
    }

    // 抓取數據並更新列表
    function fetchTextData() {
      axios.get('/text')
        .then((response) => {
          const textList = document.getElementById('textList');
          textList.innerHTML = ''; // 清空列表
          // 倒序顯示最新資料
          response.data.reverse().forEach((item) => {
            const li = document.createElement('li');
            li.className = 'bg-slate-800 p-3 rounded-lg border border-slate-700/50 shadow-sm text-slate-300 flex justify-between items-start group';

            const textSpan = document.createElement('span');
            textSpan.className = 'break-all';
            textSpan.textContent = item.text;

            const delBtn = document.createElement('button');
            delBtn.innerHTML = `
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              `;
            delBtn.className = 'text-slate-500 hover:text-red-400 p-1 rounded transition opacity-0 group-hover:opacity-100 flex-shrink-0 ml-2 focus:opacity-100 outline-none';
            delBtn.onclick = () => deleteText(item.id);

            li.appendChild(textSpan);
            li.appendChild(delBtn);
            textList.appendChild(li);
          });
        })
        .catch((error) => console.error('獲取數據失敗:', error));
    }

    // 頁面加載時獲取所有數據
    window.onload = function () {
      fetchTextData();
      fetchFileContent();
    };
  </script>
</body>

</html>